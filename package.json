{
  "name": "higoods-vanilla-clone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check:menu-routes": "node scripts/check-menu-routes.mjs",
    "check:fcs-truth-sources": "node scripts/check-fcs-truth-sources.mjs --write-report",
    "check:pda-settlement-ia": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-pda-settlement-ia.ts",
    "check:pda-settlement-profile": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-pda-settlement-profile.ts",
    "check:pda-settlement-ledger": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-pda-settlement-ledger.ts",
    "check:pda-settlement-task-links": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-pda-settlement-task-links.ts",
    "check:quality-deduction-analysis": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-quality-deduction-analysis.ts",
    "check:quality-deduction-closure": "node --experimental-strip-types scripts/check-quality-deduction-closure.ts",
    "check:quality-deduction-domain": "node --experimental-strip-types scripts/check-quality-deduction-domain.ts",
    "check:quality-deduction-final-closure": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/check-quality-deduction-final-closure.ts",
    "check:quality-deduction-lifecycle": "node --experimental-strip-types scripts/check-quality-deduction-lifecycle.ts",
    "check:quality-deduction-platform": "node --experimental-strip-types scripts/check-quality-deduction-platform.ts",
    "check:quality-deduction-mobile": "node --experimental-strip-types scripts/check-quality-deduction-mobile.ts"
  },
  "dependencies": {
    "lucide": "^0.468.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vite": "^6.2.0"
  }
}
